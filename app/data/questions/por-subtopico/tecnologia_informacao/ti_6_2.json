    {
      "id": "PCAL-TI-10-S01-011",
      "concursoId": "pc_al_2026",
      "cargoId": "agente_policia",
      "disciplinaId": "tecnologia_informacao",
      "topicoEditalId": "ti_6_2",
      "subtopic_id": "ti_6_2",
      "assunto": "Análise de Informações - Teoria da Informação - Multibancas",
      "subtopico": "Análise de Informações - Teoria da Informação - Multibancas",
      "microtopico": "",
      "banca": "CEBRASPE",
      "ano": 2021,
      "fonteProva": "CESPE / PF - 2021",
      "tipo": "certo_errado",
      "enunciado": "Os dados estruturados diferenciam-se dos dados não estruturados pela\n    rigidez em seu formato e pelo fato de poderem ser armazenados em campos de tabelas de um\n    banco de dados relacional.",
      "contextoCompartilhado": "",
      "alternativas": [],
      "respostaCorreta": "C",
      "explicacao": "Perfeito! Esta questão trata da distinção entre dados estruturados e não estruturados. Os dados\nestruturados são aqueles que possuem um formato definido e organizado, facilitando seu\narmazenamento, acesso e análise. Eles são comumente armazenados em bancos de dados\nrelacionais, onde cada elemento de dado está organizado em tabelas, linhas e colunas, permitindo\nque sejam facilmente acessados e manipulados por meio de consultas estruturadas, como SQL.\n\nPor outro lado, dados não estruturados não possuem um formato ou modelo predefinido, o que os\ntorna mais desafiadores para serem gerenciados e analisados usando métodos tradicionais.\nExemplos de dados não estruturados incluem textos, imagens, vídeos, e-mails e postagens em\nredes sociais. Eles geralmente requerem técnicas mais complexas de processamento e\narmazenamento, como o uso de sistemas de arquivos ou bancos de dados NoSQL.\n\nLogo, a afirmação da questão é correta ao destacar a rigidez no formato e a capacidade de\narmazenamento em bancos de dados relacionais como características distintivas dos dados\nestruturados em comparação com os não estruturados.",
      "status": "revisada",
      "versao": 1,
      "dificuldade": "",
      "pegadinhaDaBanca": "",
