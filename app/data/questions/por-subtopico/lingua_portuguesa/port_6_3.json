    {
      "id": "DETONA-LP-6-3-007",
      "concursoId": "pc_al_2026",
      "cargoId": "agente_policia",
      "disciplinaId": "lingua_portuguesa",
      "topicoEditalId": "port_6_3",
      "subtopic_id": "port_6_3",
      "assunto": "Reestruturação com alteração lexical",
      "subtopico": "Reorganização estrutural de frases",
      "microtopico": "",
      "banca": "CEBRASPE",
      "ano": 2026,
      "fonteProva": "QUESTÃO DETONA INÉDITA — padrão CEBRASPE",
      "tipo": "certo_errado",
      "enunciado": "Julgue o item a seguir. A frase “A testemunha afirmou que não reconhecia o suspeito” pode ser substituída por “A testemunha afirmou não ter visto o suspeito” sem alteração das informações veiculadas.",
      "contextoCompartilhado": "",
      "alternativas": [],
      "respostaCorreta": "E",
      "explicacao": "Errado. Não reconhecer alguém não equivale a não o ter visto: a testemunha pode ter visto o suspeito e, ainda assim, não tê-lo reconhecido. A nova estrutura é gramatical, mas modifica o conteúdo semântico.",
      "status": "revisada",
      "versao": 1,
      "dificuldade": "media",
      "pegadinhaDaBanca": "",
