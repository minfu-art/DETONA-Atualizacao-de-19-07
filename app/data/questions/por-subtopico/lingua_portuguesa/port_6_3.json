      }
    },
    {
      "id": "DETONA-LP-6-3-002",
      "concursoId": "pc_al_2026",
      "cargoId": "agente_policia",
      "disciplinaId": "lingua_portuguesa",
      "topicoEditalId": "port_6_3",
      "subtopic_id": "port_6_3",
      "assunto": "Deslocamento de oração concessiva",
      "subtopico": "Reorganização estrutural de frases",
      "microtopico": "",
      "banca": "CEBRASPE",
      "ano": 2026,
      "fonteProva": "QUESTÃO DETONA INÉDITA — padrão CEBRASPE",
      "tipo": "certo_errado",
      "enunciado": "Julgue o item a seguir. No período “Embora o sistema estivesse indisponível, os peritos enviaram o relatório no prazo”, a oração iniciada por “Embora” pode ser deslocada para o final — “Os peritos enviaram o relatório no prazo, embora o sistema estivesse indisponível” — sem alteração da relação de concessão.",
      "contextoCompartilhado": "",
      "alternativas": [],
      "respostaCorreta": "C",
      "explicacao": "Certo. A oração concessiva admite deslocamento, e a conjunção “embora” continua marcando um fato contrário à expectativa que não impede o envio do relatório. A vírgula separa adequadamente as duas orações.",
      "status": "revisada",
      "versao": 1,
      "dificuldade": "media",
      "pegadinhaDaBanca": "",
      "metadata": {
        "colecao": "QUESTÕES DETONA INÉDITAS",
        "autoral": true,
        "tendenciaCebraspe": true,
        "hashQuestao": "DETONA-LP-6-3-002",
        "revisado": true,
        "mappedTopicoEditalId": "port_6_3",
        "disciplinaCurta": "port",
