# Exemplo seguro. Nunca commite valores reais ou uma service_role key.
# development | staging | production
APP_ENV=development

# off apenas em development; staging/production exigem hybrid.
CLOUD_MODE=off

# Valores públicos do cliente Supabase. A segurança depende de RLS.
SUPABASE_URL=https://example-project.supabase.co
SUPABASE_ANON_KEY=example-public-anon-key

# SDK ESM fixado. Opcional; mantenha uma versão revisada.
SUPABASE_JS_URL=https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2.49.1/+esm
