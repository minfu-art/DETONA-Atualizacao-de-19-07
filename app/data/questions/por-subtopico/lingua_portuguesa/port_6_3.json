  "questions": [
    {
      "id": "DETONA-LP-6-3-001",
      "concursoId": "pc_al_2026",
      "cargoId": "agente_policia",
      "disciplinaId": "lingua_portuguesa",
      "topicoEditalId": "port_6_3",
      "subtopic_id": "port_6_3",
      "assunto": "Reorganização de oração temporal",
      "subtopico": "Reorganização estrutural de frases",
      "microtopico": "",
      "banca": "CEBRASPE",
      "ano": 2026,
      "fonteProva": "QUESTÃO DETONA INÉDITA — padrão CEBRASPE",
      "tipo": "certo_errado",
      "enunciado": "Julgue o item a seguir. A reescrita de “A equipe concluiu a análise depois que recebeu todos os laudos” como “Depois de receber todos os laudos, a equipe concluiu a análise” mantém a correção gramatical e o sentido temporal do período original.",
      "contextoCompartilhado": "",
      "alternativas": [],
      "respostaCorreta": "C",
      "explicacao": "Certo. A oração desenvolvida “depois que recebeu todos os laudos” foi reduzida para “depois de receber todos os laudos”. Como o sujeito implícito de “receber” continua sendo “a equipe”, preservam-se a relação temporal e o sentido original.",
      "status": "revisada",
      "versao": 1,
      "dificuldade": "media",
      "pegadinhaDaBanca": "",
      "metadata": {
        "colecao": "QUESTÕES DETONA INÉDITAS",
        "autoral": true,
        "tendenciaCebraspe": true,
        "hashQuestao": "DETONA-LP-6-3-001",
        "revisado": true,
        "mappedTopicoEditalId": "port_6_3",
        "disciplinaCurta": "port",
        "organizadoEm": "2026-07-21T02:11:29.714Z",
