    {
      "id": "DETONA-LP-6-3-005",
      "concursoId": "pc_al_2026",
      "cargoId": "agente_policia",
      "disciplinaId": "lingua_portuguesa",
      "topicoEditalId": "port_6_3",
      "subtopic_id": "port_6_3",
      "assunto": "Escopo do advérbio somente",
      "subtopico": "Reorganização estrutural de frases",
      "microtopico": "",
      "banca": "CEBRASPE",
      "ano": 2026,
      "fonteProva": "QUESTÃO DETONA INÉDITA — padrão CEBRASPE",
      "tipo": "certo_errado",
      "enunciado": "Julgue o item a seguir. Em “Somente após a perícia, a autoridade liberou o local”, o deslocamento de “somente” para antes do verbo, formando “A autoridade somente liberou o local após a perícia”, conserva necessariamente o mesmo foco semântico.",
      "contextoCompartilhado": "",
      "alternativas": [],
      "respostaCorreta": "E",
      "explicacao": "Errado. No original, “somente” restringe o momento da liberação: ela ocorreu apenas após a perícia. Na reescrita, o advérbio pode incidir sobre “liberou”, sugerindo que a autoridade apenas liberou o local e não realizou outra ação; o foco deixa de ser necessariamente o mesmo.",
      "status": "revisada",
      "versao": 1,
      "dificuldade": "alta",
      "pegadinhaDaBanca": "",
      "metadata": {
        "colecao": "QUESTÕES DETONA INÉDITAS",
        "autoral": true,
        "tendenciaCebraspe": true,
        "hashQuestao": "DETONA-LP-6-3-005",
