# Copie para app/js/config/env.js (campos ENV) ou injete window.__DETONA_ENV__
# Nunca commite a service_role key.

# Supabase project URL (Settings → API)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Chave anon/public (Settings → API) — segura no browser com RLS
SUPABASE_ANON_KEY=your-anon-key

# off = só local | hybrid = auth + sync de progresso
CLOUD_MODE=off
